#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT_DIR"
mkdir -p backend/logs

# shellcheck disable=SC1091
source "$ROOT_DIR/load-env.sh"

PID_FILE="backend/logs/api.pid"
LOG_FILE="backend/logs/api.log"

if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" >/dev/null 2>&1; then
  echo "api 已在运行，PID=$(cat "$PID_FILE")"
  exit 0
fi

echo "使用后台方式启动 api..."
bash -lc "source '$ROOT_DIR/load-env.sh' && source /root/miniconda3/etc/profile.d/conda.sh && conda activate video && cd '$ROOT_DIR/backend' && exec python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8000" >"$LOG_FILE" 2>&1 &
echo $! > "$PID_FILE"
echo "api 已启动，PID=$(cat "$PID_FILE")，日志：$LOG_FILE"
