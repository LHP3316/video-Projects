# Copy this file to .env and fill in your real values.
# Proxy settings used by backend httpx and frontend build steps.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=127.0.0.1,localhost

# OpenAI base URL. Leave the default official endpoint unless you use a gateway.
OPENAI_BASE_URL=https://api.openai.com

# DMXAPI settings used by 即梦 / 可灵 / OpenAI 文生图与图生视频接口.
DMXAPI_BASE_URL=https://www.dmxapi.cn
DMXAPI_API_KEY=

# Kling and Volcengine visual API base settings.
KLING_BASE_URL=https://api-beijing.klingai.com
VOLCENGINE_VISUAL_BASE_URL=https://visual.volcengineapi.com
VOLCENGINE_VISUAL_REGION=cn-north-1
VOLCENGINE_VISUAL_SERVICE=cv
